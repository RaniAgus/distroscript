{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File with Arguments",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/distroscript.py",
      "console": "integratedTerminal",
      "args": [
        "${file}",
        "--os",
        "${input:os}"
      ]
    }
  ],
  "inputs": [
    {
      "id": "os",
      "description": "Select the target operating system",
      "type": "pickString",
      "options": ["fedora", "ubuntu"]
    }
  ]
}
